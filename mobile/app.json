{
  "expo": {
    "name": "SEBPS",
    "slug": "sebps-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sebps.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2563EB"
      },
      "package": "com.sebps.mobile"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#2563EB"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow SEBPS to access your photos to scan electricity bills."
        }
      ],
      "expo-asset",
      "expo-font",
      "expo-status-bar"
    ]
  }
}
