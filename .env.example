# ─────────────────────────────────────────────────────────────────────────────
# SEBPS root environment — used by the root docker-compose.yml
#
# Steps:
#   1.  cp .env.example .env
#   2.  Set HOST_IP to your machine's LAN IP (the IP your phone can reach).
#         macOS:  ipconfig getifaddr en0
#         Linux:  hostname -I | awk '{print $1}'
#   3.  Make sure backend/.env exists with GROQ_API_KEY, etc.
#         cp backend/.env.example backend/.env   (if a template exists)
#   4.  docker compose up --build
# ─────────────────────────────────────────────────────────────────────────────

# Your machine's LAN IP address.
# Used for: mobile QR code, CORS origins, ALLOWED_HOSTS.
HOST_IP=192.168.1.52
