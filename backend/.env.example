DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL (with TimescaleDB extension)
DATABASE_URL=postgres://sebps:sebps_pass@localhost:5432/sebps_db

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# JWT
ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=7

# CORS (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# File uploads
MEDIA_ROOT=media/
MAX_UPLOAD_SIZE_MB=10

# Groq (chatbot)
GROQ_API_KEY=your-groq-api-key

# Sentry (optional)
SENTRY_DSN=

# Module paths (Python path to existing modules)
PREDICTOR_MODULE_PATH=../../module_1_predictor
OCR_MODULE_PATH=../../module_2_ocr
FETCHER_MODULE_PATH=../../module_3_fetcher
RECOMMENDER_MODULE_PATH=../../module_4_recommender
CHATBOT_MODULE_PATH=../../module_5_chatbot
